{
  "manifest_version": 3,
  "name": "IRCTC LAK AUTO",
  "version": "1.1.0",
  "description": "Save your details and autofill forms on websites.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://lakshadweep.irctc.co.in/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Autofill Assistant"
  },
  "content_scripts": [
    {
      "matches": ["https://lakshadweep.irctc.co.in/*"],
      "js": ["content.js", "seatMonitor.js"],
      "run_at": "document_idle"
    }
  ]
}
